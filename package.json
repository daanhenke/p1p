{
  "name": "@p1p/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Generic, multi-game console-romhacking toolkit (formats, XML-patch sources, disc builder) — home of the Persona 1 English patch.",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -b && pnpm --filter @p1p/wizard typecheck"
  },
  "devDependencies": {
    "7.css": "^0.21.1",
    "@eslint/js": "^9.18.0",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.9",
    "xp.css": "^0.2.6"
  }
}
